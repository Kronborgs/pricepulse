# ─── Application ──────────────────────────────────────────────
# PÅKRÆVET: Generer med: openssl rand -hex 32
# VIGTIGT: Skift dette inden produktion — standard er usikker!
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ANBEFALET: Generer Fernet-nøgle til kryptering af SMTP-kodeord i DB:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Hvis tom bruges SECRET_KEY som basis (ikke anbefalet).
# FERNET_KEY=

# Sæt til true hvis frontenden serveres over HTTPS (påkrævet for sikre cookies)
# COOKIE_SECURE=true

# ─── Database ──────────────────────────────────────────────────
# PÅKRÆVET: Skift kodeord inden produktion!
POSTGRES_USER=pricepulse
POSTGRES_PASSWORD=skift-mig-inden-produktion
POSTGRES_DB=pricepulse
POSTGRES_HOST=pricepulse-db
POSTGRES_PORT=5432

# Fuld database URL (bruges af backend) — skift kodeord!
DATABASE_URL=postgresql+asyncpg://pricepulse:skift-mig-inden-produktion@pricepulse-db:5432/pricepulse

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://pricepulse-redis:6379/0

# ─── Backend ───────────────────────────────────────────────────
# "production" | "development"
ENVIRONMENT=production

# Tilladt CORS origins (kommasepareret)
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Scraper ───────────────────────────────────────────────────
# Sekunder mellem requests til samme domæne (rate limiting)
SCRAPER_DOMAIN_DELAY=5

# Max requests i queue ad gangen
SCRAPER_MAX_CONCURRENT=4

# User-Agent header
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; PricePulse/1.0; +https://github.com/Kronborgs/pricepulse)

# Playwright headless browser (true/false)
PLAYWRIGHT_ENABLED=false

# ─── Frontend ──────────────────────────────────────────────────
# URL som frontend bruger til at kalde backend API
# Fra browser til backend (kan være intern docker-hostname eller ekstern IP)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Unraid / Deployment ───────────────────────────────────────
# PUID / PGID — match med Unraid user (standard 99:100)
PUID=1001
PGID=1001
TZ=Europe/Copenhagen

# ─── Docker Networks (Unraid) ──────────────────────────────────
# Netværk som backend, db og redis bruger (skal eksistere på serveren)
BACKEND_NETWORK=dockernet
# Netværk som frontend bruger (f.eks. reverse proxy network)
FRONTEND_NETWORK=cloudflared
