<?xml version="1.0"?>
<Container version="2">
  <Name>pricepulse-redis</Name>
  <Repository>redis:7-alpine</Repository>
  <Registry>https://hub.docker.com/_/redis</Registry>
  <Network>dockernet</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Kronborgs/pricepulse</Support>
  <Project>https://github.com/Kronborgs/pricepulse</Project>
  <Overview>Redis 7 cache til PricePulse. Skal køre på samme netværk som pricepulse-backend.</Overview>
  <Category>Tools:</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/Kronborgs/pricepulse/main/unraid/pricepulse-redis.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Kronborgs/pricepulse/main/assets/icon.png</Icon>
  <ExtraParams>--appendonly yes --maxmemory 256mb --maxmemory-policy allkeys-lru</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires>pricepulse-backend network (dockernet)</Requires>
  <Config Name="Data" Target="/data" Default="/mnt/user/appdata/pricepulse/redis" Mode="rw" Description="Redis data mappe" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pricepulse/redis</Config>
  <Config Name="Time Zone" Target="TZ" Default="Europe/Copenhagen" Mode="" Description="Tidszone" Type="Variable" Display="always" Required="false" Mask="false">Europe/Copenhagen</Config>
</Container>
