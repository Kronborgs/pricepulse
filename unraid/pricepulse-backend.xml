<?xml version="1.0"?>
<Container version="2">
  <Name>pricepulse-backend</Name>
  <Repository>ghcr.io/kronborgs/pricepulse-backend:latest</Repository>
  <Registry>https://github.com/Kronborgs/pricepulse/pkgs/container/pricepulse-backend</Registry>
  <Network>dockernet</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Kronborgs/pricepulse</Support>
  <Project>https://github.com/Kronborgs/pricepulse</Project>
  <Overview>Backend til PricePulse — alt-i-én container med FastAPI + APScheduler + PostgreSQL 16 + Redis 7. Ingen separate database-containere nødvendige.</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:8000]/docs</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Kronborgs/pricepulse/main/unraid/pricepulse-backend.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Kronborgs/pricepulse/main/assets/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="API Port" Target="8000" Default="8000" Mode="tcp" Description="Porten som PricePulse API er tilgængeligt på" Type="Port" Display="always" Required="true" Mask="false">8000</Config>
  <Config Name="App Data" Target="/app/data" Default="/mnt/user/appdata/pricepulse/app" Mode="rw" Description="Persistente data for backend" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pricepulse/app</Config>
  <Config Name="PostgreSQL Data" Target="/var/lib/postgresql/data" Default="/mnt/user/appdata/pricepulse/postgres" Mode="rw" Description="PostgreSQL database filer (persistens)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pricepulse/postgres</Config>
  <Config Name="Redis Data" Target="/data" Default="/mnt/user/appdata/pricepulse/redis" Mode="rw" Description="Redis persistens-mappe" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pricepulse/redis</Config>
  <Config Name="Database User" Target="POSTGRES_USER" Default="pricepulse" Mode="" Description="Brugernavn til den indbyggede PostgreSQL database" Type="Variable" Display="always" Required="true" Mask="false">pricepulse</Config>
  <Config Name="Database Password" Target="POSTGRES_PASSWORD" Default="changeme" Mode="" Description="Adgangskode til PostgreSQL — skift til din egen" Type="Variable" Display="always" Required="true" Mask="true">changeme</Config>
  <Config Name="Database Name" Target="POSTGRES_DB" Default="pricepulse" Mode="" Description="Navn på PostgreSQL databasen" Type="Variable" Display="always" Required="true" Mask="false">pricepulse</Config>
  <Config Name="Secret Key" Target="SECRET_KEY" Default="" Mode="" Description="Generer med: openssl rand -hex 32" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="CORS Origins" Target="CORS_ORIGINS" Default="http://192.168.1.50:3000" Mode="" Description="URL til frontend — brug din Unraid servers LAN-IP og port 3000. Eks: http://192.168.1.50:3000. Skal ændres til din Domain eller subdomain du laver via Reverse Proxy" Type="Variable" Display="always" Required="true" Mask="false">http://192.168.1.50:3000</Config>
  <Config Name="Frontend URL" Target="FRONTEND_URL" Default="http://192.168.1.50:3000" Mode="" Description="URL brugeren tilgår frontenden fra — bruges i emails (glemt kodeord, notifikationer). Skal matche CORS Origins. Eks LAN: http://192.168.1.50:3000 — Eks HTTPS: https://pricepulse.ditdomæne.dk. Skal ændres til din Domain eller subdomain du laver via Reverse Proxy" Type="Variable" Display="always" Required="true" Mask="false">http://192.168.1.50:3000</Config>
  <Config Name="Cookie Secure" Target="COOKIE_SECURE" Default="false" Mode="" Description="Sæt til true HVIS du tilgår via HTTPS (Reverse Proxy med SSL). Skal være false ved plain HTTP (standard LAN-opsætning uden HTTPS)" Type="Variable" Display="always" Required="false" Mask="false">false</Config>
  <Config Name="Environment" Target="ENVIRONMENT" Default="production" Mode="" Description="production eller development" Type="Variable" Display="advanced" Required="false" Mask="false">production</Config>
  <Config Name="Log Level" Target="LOG_LEVEL" Default="INFO" Mode="" Description="DEBUG, INFO, WARNING eller ERROR" Type="Variable" Display="advanced" Required="false" Mask="false">INFO</Config>
  <Config Name="Scraper Domain Delay" Target="SCRAPER_DOMAIN_DELAY" Default="5" Mode="" Description="Sekunder mellem requests til samme domæne (rate limiting)" Type="Variable" Display="advanced" Required="false" Mask="false">5</Config>
  <Config Name="Max Concurrent Scrapers" Target="SCRAPER_MAX_CONCURRENT" Default="4" Mode="" Description="Max antal parallelle scraper-requests" Type="Variable" Display="advanced" Required="false" Mask="false">4</Config>
  <Config Name="Playwright Enabled" Target="PLAYWRIGHT_ENABLED" Default="false" Mode="" Description="Aktiver headless browser til Cloudflare-beskyttede sider (kræver mere RAM)" Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="Time Zone" Target="TZ" Default="Europe/Copenhagen" Mode="" Description="Find din tidszone her: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones" Type="Variable" Display="always" Required="false" Mask="false">Europe/Copenhagen</Config>
</Container>
