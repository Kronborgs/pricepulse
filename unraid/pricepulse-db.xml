<?xml version="1.0"?>
<Container version="2">
  <Name>pricepulse-db</Name>
  <Repository>postgres:16-alpine</Repository>
  <Registry>https://hub.docker.com/_/postgres</Registry>
  <Network>dockernet</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Kronborgs/pricepulse</Support>
  <Project>https://github.com/Kronborgs/pricepulse</Project>
  <Overview>PostgreSQL 16 database til PricePulse. Skal køre på samme netværk som pricepulse-backend.</Overview>
  <Category>Tools:</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/Kronborgs/pricepulse/main/unraid/pricepulse-db.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Kronborgs/pricepulse/main/assets/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires>pricepulse-backend network (dockernet)</Requires>
  <Config Name="Data" Target="/var/lib/postgresql/data" Default="/mnt/user/appdata/pricepulse/postgres" Mode="rw" Description="PostgreSQL data mappe" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pricepulse/postgres</Config>
  <Config Name="Postgres User" Target="POSTGRES_USER" Default="pricepulse" Mode="" Description="Database brugernavn" Type="Variable" Display="always" Required="true" Mask="false">pricepulse</Config>
  <Config Name="Postgres Password" Target="POSTGRES_PASSWORD" Default="changeme" Mode="" Description="Database password — skift til dit eget" Type="Variable" Display="always" Required="true" Mask="true">changeme</Config>
  <Config Name="Postgres DB" Target="POSTGRES_DB" Default="pricepulse" Mode="" Description="Database navn" Type="Variable" Display="always" Required="true" Mask="false">pricepulse</Config>
  <Config Name="Time Zone" Target="TZ" Default="Europe/Copenhagen" Mode="" Description="Tidszone" Type="Variable" Display="always" Required="false" Mask="false">Europe/Copenhagen</Config>
</Container>
